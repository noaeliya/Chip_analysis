# משתמשים באימג' רשמי ורזה של פייתון
FROM python:3.11-slim

# הגדרת תיקיית העבודה בתוך הקונטיינר
WORKDIR /app

# העתקת קובץ הדרישות (אם יש לך) או התקנה ישירה של הספריות
# מומלץ להתקין את Flask ו-Flask-CORS שבהן השתמשנו
RUN pip install --no-cache-dir flask flask-cors

# העתקת כל קבצי קוד המקור של השרת לתוך הקונטיינר
COPY . .

# חשיפת הפורט של השרת (5000) כלפי חוץ
EXPOSE 5000

# פקודת ההרצה של השרת
CMD ["python", "app.py"]